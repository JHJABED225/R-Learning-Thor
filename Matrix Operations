# Creating a Matrix with 2 rows and 4 columns, filling cells from 1 to 8


mat<- matrix(c(1:8), byrow = TRUE, nrow= 2, 
             dimnames = list(c("AB", "CD"), c("X", "Y", "Z"))    
            )
mat 

# dimnames means dimension names. It will show AB, CD in left row level and X, Y Z, W to the top level. 
# dmnames must cover the number of rows and columns. 
