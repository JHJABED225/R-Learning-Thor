

#=========================================================
# for loops: 
# Syntax: for(var in seq) { expression}
#=========================================================

#===========================================================================================================================
# Task: Create a variable cities and print them using for loop. 
#===========================================================================================================================

cities <- c("New York", "Paris", "London", "Tokyo", "Rio de Janeiro", "Cape Town")
for(city in cities) {
  print(city) 
  }

#The result is same for list too. 

cities <- list("New York", "Paris", "London", "Tokyo", "Rio de Janeiro", "Cape Town")
for(city in cities) {
  print(city) 
}

#=========================================================
#Break usage in for loops
#=========================================================

#===========================================================================================================================
# Task: Print cities as long as nchar(number of character) is 6.
#===========================================================================================================================

cities <- list("New York", "Paris", "London", "Tokyo", "Rio de Janeiro", "Cape Town")
for(city in cities) {
  if(nchar(city)==6) {
    break
  }
  print(city) 
}
# This will only print "New York" and "Paris"

#===========================================================================================================================
# Task: Print cities except number of character is 6. 
#===========================================================================================================================

cities <- list("New York", "Paris", "London", "Tokyo", "Rio de Janeiro", "Cape Town")
for(city in cities) {
  if(nchar(city)==6) {
    next
  }
  print(city) 
}

#=========================================================
# introducing i in for loops (for vector, not list)
#=========================================================

cities <- c("New York", "Paris", "London", "Tokyo", "Rio de Janeiro", "Cape Town")
for(i in 1:length(cities)) {
  print(cities[i]) 
}

#===========================================================================================================================
#Task: Write down the cities name as format: New York is in the position 1 in the cities vector.
#===========================================================================================================================

cities <- c("New York", "Paris", "London", "Tokyo", "Rio de Janeiro", "Cape Town")
for(i in 1:length(cities)) {
  print(paste(cities[i], "is in the position", i, "in the cities vector")) #paste function is mandatory here. Does not work for list.
}

