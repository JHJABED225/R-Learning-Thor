# Task: Pre-defined variables
#===========================================================================================================================

rquote <- "r's internals are irrefutably intriguing"     #This can be set as function(text) and then inside strsplit, use text in the first portion. 
chars <- strsplit(rquote, split = "")[[1]]

rcount <- 0   # Initialize rcount

for (char in chars) {     # Finish the for loop
  if(char=="r") {
    rcount<- rcount+1
  }
  if(char=="u"){
    break
  } 
}
# Print out rcount
rcount

