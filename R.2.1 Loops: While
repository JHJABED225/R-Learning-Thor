

#===========================================================================================================================
# Task: If the speed is greater than 48, have R print out "Slow down big time!", and decrease the speed by 11.
# Otherwise, have R simply print out "Slow down!", and decrease the speed by 6.
#===========================================================================================================================

speed <- 64         # Initialize the speed variable
while (speed > 30) {
  print(paste("Your speed is", speed))
  if (speed>48) {
    print("Slow down big time!")
    speed <- speed-11
  } else {
    print("Slow down!")
    speed <- speed-6
  }
}

#===========================================================================================================================
# Adapt the while loop such that it is abandoned when the speed of the vehicle is greater than 80. 
# This time, the speed variable has been initialized to 88; keep it that way.
#===========================================================================================================================

speed <- 88

while (speed > 30) {
  print(paste("Your speed is", speed))
  
  if (speed>80) {        # Break the while loop when speed exceeds 80
    break
  }
  if (speed > 48) {
    print("Slow down big time!")
    speed <- speed - 11
  } else {
    print("Slow down!")
    speed <- speed - 6
  }
}


#===========================================================================================================================
# prints out the triple of i, so 3 * i, at each run.
# is abandoned with a break if the triple of i is divisible by 8.
#===========================================================================================================================

num<- 1
while(num<=10){
  print(num *3)
  if((num*3)%%8==0){
    break
  }
  num<- num+1
}
This will show: 3,6,,,,,,,24

#===========================================================================================================================
# Do the above task that exclude the number divisible by 8.
#===========================================================================================================================

num<- 1
while(num<=10){
  print(num *3)
  num<- num+1
  if((num*3)%%8==0){
    break
  }
}
This will show: 3,6,,,,,,,21



