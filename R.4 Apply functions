#===========================================================================================================================
# Task: Create a vector "cities" and find their legth of each cities
#===========================================================================================================================

cities<- c("New York", "Paris", "London", "Tokyo", 
           "Rio de Janerio", "Cape Town")
# Procedure-1: 
num_chars<- c()
for(i in 1:length(cities)) {
  num_chars[i]<- nchar(cities[i])
}
num_chars

# Procedure-2: 
lapply(cities, nchar)     #This will provide the result as a list irrespective of what provided. 

unlist(lapply(cities, nchar))    #This will provide the results as a vector. 

#===========================================================================================================================
# Create vector oil_prices and function multiply, then use multiply function and apply function to find the 4times of oil_prices
#===========================================================================================================================
oil_prices<- c(2.37,2.49,2.18,2.22,2.47,2.32)
multiply<- function(x, factor){
  x*factor 
}

multiply(oil_prices, 4) 
unlist(lapply(oil_prices, multiply, factor= 4))      #result will be provided as vector. 


