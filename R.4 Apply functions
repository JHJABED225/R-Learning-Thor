# Task: Create a vector pioneers, then split the name and birthyear using strsplit
# Then convert the names into lowercase and find the structure of new split_low
#===========================================================================================================================

pioneers <- c("GAUSS:1777", "BAYES:1702", "PASCAL:1623", "PEARSON:1857")

split_math <- strsplit(pioneers, split = ":")       # Split names from birth year

split_low<- lapply(split_math, tolower)         # Convert to lowercase strings: split_low

str(split_low)                     # Take a look at the structure of split_low


