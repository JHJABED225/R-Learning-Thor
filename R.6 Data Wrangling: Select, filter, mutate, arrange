
# select: 
    # select is used to pick the specific column from a table/dataset.
    # starts_with(" "), ends_with(" ") selects all those column that starts or ends with specific substring. 
    # contains(" ") select all those column that  contains specific part. 
    # last_cols(), returns the last column of a dataset. 
    # matches(" ") returns column that match specific characters. 
    # -column name, provide all columns except the given one. 


# filter: 
    # extracts observations based on conditions. 
    # filter creates a new subset.
    # filter(year== 2007, country== "Bangladesh")         # Rows where both condition meet, the observations are provided. 
    # filter(year== 2007 | country=="Bangladesh")         #If observations either from country Bangladesh or from year 2007, are showed. 

# arrange: 
    # arrange sorts the observations either ascending(default) or descending based on one or more provided condition (column name) 
    #

# mutate: 
    # mutate changes the existent variable or can create new variable.  
    # mutate can do the task of select(): mutate( columns to be selected, applied column function, .keep="none") 



#===========================================================================================================================
# Task: Filter observations where country is Bangladesh or Year is 2007.
# Task: Filter observations where country is Bangladesh and Year is 2007.
#===========================================================================================================================

gp<- gapminder %>% 
    filter(year==2007 | country== "Bangladesh")
View(gp)

gp<- gapminder %>% 
    filter(year==2007, country=="Bangladesh")
View(gp)


#===========================================================================================================================
# Task: Sort the gapminder dataset according to year. Ascending and Descending (2 times sorting)
#===========================================================================================================================

gp<- gapminder %>% 
    arrange(year)     # By default ascending order. 
View(gp)
  
gp<- gapminder %>%
    arrange(desc(year))   # Mention desc before year to sort in descending order. 
View(gp)


#===========================================================================================================================
# Task: Filter for year 2007 then Divide pop by 100000 and sort by pop descending. 
#===========================================================================================================================

gp<- gapminder %>% 
    filter(year== 2007) %>% 
    mutate(pop= round(pop/100000,2)) %>%
    arrange(desc(pop))
View(gp)

