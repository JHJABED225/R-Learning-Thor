
# ggplot: gg means grammer of graphics. 

 # To create scatterplot, add geom_point() after ggplot
 # To create line graph, add geom_line() after ggplot. 
 # To create bar diagram, add geom_col. 
 # 




  # facet: facet_wrap converts the plot into several small subplots. It is written at the end of all commands. 
    # facet_wrap( ~ column name). This will create several subplot for specified column name. 




#===========================================================================================================================
# Task: Show a scatterplot using pop and lifeExp from gapminder_1952. color and size according to continent and gdpPercap.
#===========================================================================================================================

library(gapminder)
library(dplyr)
library(ggplot2)

gapminder_1952 <- gapminder %>%
  filter(year == 1952)

ggplot(gapminder_1952,aes(x=pop, y=lifeExp, color=continent, size=gdpPercap)) +
  geom_point() +
  scale_x_log10() 


#===========================================================================================================================
# Task: Scatter plot comparing gdpPercap and lifeExp, with color representing continent
# and size representing population, faceted by year
#===========================================================================================================================

ggplot(gapminder, aes(x=gdpPercap, y= lifeExp, color= continent, size= pop )) +
      geom_point() +      # Mandatory to show the points. 
      scale_x_log10() +   # Solve scaling problems. 
      facet_wrap(~ year)  # Creates subplot according to year


#===========================================================================================================================
# Task: Calculate the mean life expectancymedian gdpPercap by continent in 1952 and show bar diagram.
#===========================================================================================================================
by_continent<- gapminder %>% 
        filter(year==1952) %>% 
        group_by(continent) %>% 
        summarize(medianGdpPercap= median(gdpPercap))

ggplot(by_continent, aes(x=continent, y= medianGdpPercap)) + geom_col() 



#===========================================================================================================================
# Filter gapminder for Oceania and year 1952, then display bar plot for country and gdpPercap. 
#===========================================================================================================================

oceania_1952 <- gapminder %>% 
  filter(continent=="Oceania", year== 1952)

ggplot(oceania_1952, aes(country, gdpPercap)) + geom_col() 






