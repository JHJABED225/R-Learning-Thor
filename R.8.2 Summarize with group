


#===========================================================================================================================
# Task: Filter for 1957 then summarize the median life expectancy from gapminder. 
#===========================================================================================================================

gapminder %>% 
    filter(year== 1957) %>% 
    summarize(medianLifeExp = median(lifeExp))

#===========================================================================================================================
# Task: Filter for 1957 then summarize the median life expectancy and the maximum GDP per capita
#===========================================================================================================================

gapminder %>% 
    filter(year==1957) %>%
    summarize(medianLifeExp= median(lifeExp), 
                maxGdpPercap= max(gdpPercap))
